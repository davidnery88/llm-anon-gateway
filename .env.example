# ─────────────────────────────────────────────────────────────
# Configuration LLM Anonymization Gateway — copier vers .env
#   cp .env.example .env  &&  remplir les valeurs
# Ne jamais committer le .env (ignoré par .gitignore).
# ─────────────────────────────────────────────────────────────

# ── Gateway (serveur LAN) — docker-compose.yml ──
# Mot de passe PostgreSQL (sert à construire POSTGRES_DSN)
POSTGRES_PASSWORD=changeme
# URL de l'API Ollama (classification colonnes via qwen3-pii)
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3-pii
# Secret de l'interface d'administration (/admin/*)
ADMIN_SECRET=changeme
# Clé de signature des JWT OAuth émis par /oauth/token (32+ bytes aléatoires en prod)
OAUTH_SIGNING_KEY=dev-signing-key-CHANGEME-32bytes-min
# Modèle GLiNER (laisser vide = modèle par défaut ; ou chemin vers le fine-tuné)
GLINER_MODEL=

# ── Sidecar (poste utilisateur) — sidecar/docker-compose.yml ──
REDIS_PASSWORD=changeme
REDIS_URL=redis://redis:6379
# URL du gateway LAN (HTTPS : https://host.docker.internal:3443 si certs générés)
GATEWAY_URL=http://host.docker.internal:8001
# Clé API personnelle générée via scripts/generate_api_key.py
GATEWAY_API_KEY=
# CA mkcert pour faire confiance aux certs HTTPS du gateway
SSL_CERT_FILE=/etc/ssl/certs/ca.pem
# Origine CORS autorisée depuis le frontend
ANON_SIDECAR_ALLOWED_ORIGIN=http://localhost:3000
# Token d'auth optionnel — si présent, X-Sidecar-Token requis sur tous les endpoints
ANON_SIDECAR_TOKEN=

# ── OAuth M2M (optionnel) — si les 3 vars sont set, le sidecar utilise un JWT ──
OAUTH_TOKEN_URL=
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_SCOPE=

# ── Anthropic (forward LLM) ──
ANTHROPIC_API_KEY=

# ── RunPod (GPU cloud pour entraînement Qwen) ──
RUNPOD_API_KEY=

# Scan multi-DB : clé Fernet pour chiffrer les credentials DWH au repos.
# Générer : python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DWH_ENC_KEY=
